{
  "name": "@commercelayer/cli-core",
  "version": "6.0.0-oclif4.13",
  "description": "Commerce Layer Javascript CLI core lib",
  "author": "Pierluigi Viti <pierluigi@commercelayer.io>",
  "license": "MIT",
  "repository": "github:commercelayer/commercelayer-cli-core",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.mjs",
  "exports": {
    "types": "./lib/index.d.ts",
    "require": "./lib/index.js",
    "import": "./lib/index.mjs"
  },
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test-local": "tsx test/spot.ts",
    "coverage": "vitest run --coverage",
    "lint": "biome check --enforce-assist=true",
    "check": "biome check --enforce-assist=true --write",
    "release": "pnpm upgrade && pnpm lint && pnpm build && pnpm test"
  },
  "keywords": [
    "ecommerce",
    "commercelayer"
  ],
  "files": [
    "lib/**/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "oclif": "^4.23.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@commercelayer/js-auth": "^7.4.1",
    "@oclif/core": "^4.10.5",
    "chalk": "^4.1.2",
    "jsonwebtoken": "^9.0.3",
    "update-notifier-cjs": "^5.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
